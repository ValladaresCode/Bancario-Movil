# ========================================
# CONFIGURACIÓN DE APIs - BACKEND
# Usa la IP LAN de la máquina del backend (no localhost: el dispositivo físico
# no resuelve el localhost del PC). Ajusta la IP según tu red.
# ========================================

# AuthService - Autenticación y Gestión de Usuarios (Puerto 4000)
EXPO_PUBLIC_AUTH_URL=http://192.168.0.18:4000/api/v1

# Gestor Bancario Backend - Cuentas, Transacciones, Servicios, etc. (Puerto 3006)
EXPO_PUBLIC_BANK_URL=http://192.168.0.18:3006/gestionBancaria/api/v1

# Health check del Gestor Bancario
EXPO_PUBLIC_BANK_HEALTH_URL=http://192.168.0.18:3006/health

# El proyecto navega con React Navigation; desactiva el check de expo-router en SDK 56.
EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1
