NODE_ENV=development
PORT=3006

# Forma sin +srv: los DNS de la red universitaria rechazan consultas SRV desde Node.
# Equivale a mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/gestorBancario
URI_MONGO=mongodb://localhost:27017/gestorBancarioDb

# Debe coincidir con el JWT del AuthService (valida los tokens que este emite)
JWT_SECRET=GenerarUnSecretoAleatorioDe256BitsMinimo
JWT_ISSUER=The5FadeFriends
JWT_AUDIENCE=The5FadeFriends

CLOUDINARY_CLOUD_NAME=tu-cloud
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=changeme
CLOUDINARY_FOLDER=HaircutFiveFriends/images

GEMINI_API_KEY=changeme
