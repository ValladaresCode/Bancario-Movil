# ========================================
# Plantilla de variables de entorno. Cópiala a `.env` y rellena con la IP LAN
# de la máquina donde corren los backends (no uses localhost en dispositivo físico).
# `.env` está en .gitignore y NO se versiona.
# ========================================

# AuthService - Autenticación y Gestión de Usuarios (Puerto 3900)
EXPO_PUBLIC_AUTH_URL=

# Gestor Bancario Backend - Cuentas, Transacciones, Servicios, etc. (Puerto 3006)
EXPO_PUBLIC_BANK_URL=

# Health check del Gestor Bancario
EXPO_PUBLIC_BANK_HEALTH_URL=
