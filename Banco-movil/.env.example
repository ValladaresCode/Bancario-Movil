# ========================================
# CONFIGURACIÓN DE APIs - BACKEND
# Usa la IP LAN de la máquina del backend (no localhost: el dispositivo físico
# no resuelve el localhost del PC). Ajusta la IP según tu red.
# ========================================

# AuthService - Autenticación y Gestión de Usuarios (Puerto 3900)
EXPO_PUBLIC_AUTH_URL=http://192.168.1.18:3900/api/v1

# Gestor Bancario Backend - Cuentas, Transacciones, Servicios, etc. (Puerto 3006)
EXPO_PUBLIC_BANK_URL=http://192.168.1.18:3006/gestionBancaria/api/v1

# Health check del Gestor Bancario
EXPO_PUBLIC_BANK_HEALTH_URL=http://192.168.1.18:3006/health

