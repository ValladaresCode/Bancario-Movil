NODE_ENV=development
PORT=3900

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5435
DB_NAME=auth_db
DB_USERNAME=postgres
DB_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@localhost:5435/auth_db
DB_SQL_LOGGING=false

# JWT Configuration
JWT_SECRET=GenerarUnSecretoAleatorioDe256BitsMinimo
JWT_EXPIRES_IN=30m
# Vida del access token (alto en dev para no romper la app movil sin refresh)
ACCESS_TOKEN_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=The5FadeFriends
JWT_AUDIENCE=The5FadeFriends
# Dominio de la cookie de refresh (opcional; usar en produccion con subdominios)
# COOKIE_DOMAIN=

# SMTP Configuration (Gmail: usar App Password, no la contraseña de la cuenta)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USERNAME=tu-correo@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=tu-correo@gmail.com
EMAIL_FROM_NAME=Auth GestorBancario

# Cloudinary (upload de perfiles)
CLOUDINARY_CLOUD_NAME=tu-cloud
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=changeme
CLOUDINARY_BASE_URL=https://res.cloudinary.com/tu-cloud/image/upload/
CLOUDINARY_FOLDER=HaircutFiveFriends/images
# Sin extensión: el public_id en Cloudinary no la lleva
CLOUDINARY_DEFAULT_AVATAR_FILENAME=default-avatar

# File Upload
UPLOAD_PATH=./uploads

# Frontend URL
FRONTEND_URL=http://localhost:5173
# Scheme de deep link de la app movil (enlace de reset universal web+app)
MOBILE_APP_SCHEME=bancariomovil

# Security
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_ALLOWED_ORIGINS=http://localhost:5173

# Verification Tokens (en horas)
VERIFICATION_EMAIL_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1
